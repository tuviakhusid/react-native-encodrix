{
  "expo": {
    "name": "Encodrix",
    "slug": "encodrix-scan-invoice-app",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/encodrix.png",
    "scheme": "encodrix",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.encodrix.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e3a8a",
        "foregroundImage": "./assets/images/encodrix.png",
        "backgroundImage": "./assets/images/encodrix.png",
        "monochromeImage": "./assets/images/encodrix.png"
      },
      "package": "com.encodrix.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Encodrix to access your camera to scan invoices."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Encodrix to access your photos to upload invoices."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/encodrix.png",
          "resizeMode": "contain",
          "backgroundColor": "#1e3a8a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9907ffe0-c055-430a-9e11-8d6cfb499894"
      }
    },
    "owner": "anasseth"
  }
}
